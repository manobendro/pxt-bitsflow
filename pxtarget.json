{
    "id": "bitsflow",
    "name": "Bitsflow",
    "title": "MakeCode for Bitsflow (PXT VM)",
    "nickname": "bitsflow",
    "description": "Program with Blocks, JavaScript, or Python and compile to the PXT VM bytecode (.pxt64).",
    "corepkg": "core",
    "bundleddirs": [
        "libs/base",
        "libs/core"
    ],
    "cloud": {
        "workspace": false,
        "packages": false,
        "sharing": false,
        "importing": false,
        "embedding": false,
        "githubPackages": false
    },
    "compile": {
        "isNative": true,
        "nativeType": "vm",
        "hasHex": true,
        "sourceMap": true,
        "switches": {},
        "vmOpCodes": true,
        "shortStackTraces": true
    },
    "compileService": {
        "buildEngine": "make",
        "skipCloudBuild": true,
        "serviceId": "bitsflow"
    },
    "runtime": {
        "mathBlocks": true,
        "textBlocks": true,
        "listsBlocks": true,
        "variablesBlocks": true,
        "logicBlocks": true,
        "loopsBlocks": true,
        "functionBlocks": true,
        "onStartNamespace": "basic",
        "onStartColor": "#11B5AC"
    },
    "simulator": {
        "autoRun": true,
        "aspectRatio": 1.22
    },
    "appTheme": {
        "python": true,
        "extendEditor": true,
        "hasReferenceDocs": true,
        "boardName": "Bitsflow RP2040",
        "boardNickname": "Bitsflow",
        "driveDisplayName": "RPI-RP2",
        "organization": "Bitsflow",
        "organizationText": "Bitsflow",
        "organizationShortText": "Bitsflow",
        "useTextLogo": true,
        "accentColor": "#11B5AC",
        "backgroundColor": "#1E1E1E",
        "baseTheme": "dark",
        "defaultColorTheme": "bitsflow-dark",
        "highContrastColorTheme": "pxt-high-contrast",
        "invertedMenu": true,
        "coloredToolbox": true,
        "selectLanguage": true,
        "print": true,
        "homeUrl": "/",
        "copyrightText": "Bitsflow • PXT VM for RP2040",
        "hideShareEmbed": true,
        "hideHomeDetailsVideo": true
    }
}
